# Role Assignment IDs
#
# You can find the role assignment IDs by going to the resource in the Azure Portal,
# navigating to "Access Control (IAM)" > "Role assignments", and clicking on the role
# assignment. The ID will be in the URL as the last segment. Alternatively, you can use the
# Azure CLI to list role assignments and find the relevant one.
# Example CLI command:
# az role assignment list --assignee <principal-id> --query "[].id" -o tsv
#
trino_workload_identity_storage_delegator_id = "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.Storage/storageAccounts/<storage-account-name>/providers/Microsoft.Authorization/roleAssignments/<role-assignment-id>"
trino_workload_identity_storage_contributor_id = "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.Storage/storageAccounts/<storage-account-name>/providers/Microsoft.Authorization/roleAssignments/<role-assignment-id>"
dagster_workload_identity_key_vault_user_id = "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.KeyVault/vaults/<key-vault-name>/providers/Microsoft.Authorization/roleAssignments/<role-assignment-id>"
dagster_workload_identity_acr_pull_id = "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.Authorization/roleAssignments/<role-assignment-id>"
openmetadata_workload_identity_key_vault_user_id = "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.KeyVault/vaults/<key-vault-name>/providers/Microsoft.Authorization/roleAssignments/<role-assignment-id>"

