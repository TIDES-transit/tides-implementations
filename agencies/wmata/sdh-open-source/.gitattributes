# Set the default behavior, in case people don't have core.autocrlf set
* text=auto

# C files
*.c text
*.h text

# Python files
*.py text eol=lf
*.pyi text eol=lf
*.pyx text eol=lf
*.pxd text eol=lf

# SQL files
*.sql text eol=lf
*.dbt text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.env* text eol=lf
*.env.template text eol=lf
*.env-template text eol=lf
Dockerfile* text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Binary files that should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
